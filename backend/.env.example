# ── Local LLM (ramalama / ollama) ────────────────────────────────────────────
# Run with:  python run.py --local
# Or set these and run:  python run.py
#
# USE_LOCAL_LLM=true
# MODEL_NAME=llama3.2:3b
# MODEL_BASE_URL=http://localhost:8100   # ramalama default port

# ── Remote LLM (OpenRouter / OpenAI-compatible) ───────────────────────────────
# Run with:  python run.py  (default)
#
USE_LOCAL_LLM=false
MODEL_NAME=qwen/qwen3-235b-a22b
MODEL_KEY=your-api-key-here
MODEL_BASE_URL=https://openrouter.ai/api/v1

# ── Mission parameters ────────────────────────────────────────────────────────
# GRID_SIZE=20
# BATTERY_RECALL_THRESHOLD=25
# MAX_MISSION_STEPS=50

# ── Generation parameters ─────────────────────────────────────────────────────
# TEMPERATURE=0.2
# MAX_TOKENS=1024
# NUM_CTX=8192

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# TRACE_FUNCTION_CALLS=false
